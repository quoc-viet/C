#include "stdio.h"
#include "math.h"

int ktraSNT(int x){
// Nếu mà x<=0 thì trả về giá trị 0
	if(x<=1) return 0;
	//SNT là số chỉ chia hết cho 1 và chính nó nên chỉ xét các số i trong khoảng 1<i<x 
	for(int i=2; i<=x-1; i++){
	// Nếu x chia hết cho i thì trả về giá trị 0
		if(x%i==0) return 0;
		}
	// Ngược lại trả về giá trị 1	
		return 1;
}

int main(){
	int n;
	printf("Nhap so n: ");
	scanf("%d", &n);
   int kt=ktraSNT(n);
	//Nếu ra giá trị 0 thì nó không phải là SNT và ngược lại
	if(kt==0){
		printf("Khong phai la SNT");
		}else{
			printf("La SNT");
			}
	
	}
