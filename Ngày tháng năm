#include "stdio.h"
//in ra số ngày trong tháng của 1 năm
int soNgayTrongThang(int thang, int nam){
	switch(thang){
	   case 1:
	   case 3:
	   case 5:
	   case 7:
	   case 8:
	   case 10:
	   case 12:
	     return 31;
	   case 4:
	   case 6:
	   case 9:
	   case 11:
	     return 30;
	   case 2:
     return (nam%400==0 || (nam%4==0&&nam%100!=0))?29:28;
     default:
      return -1;
	   }
}
//Ngày nhập vào là ngày thứ mấy trong năm có 365 hoặc 366 ngày		
int ngayTrongNam(int ngay, int thang, int nam){
	int ntn=0;
	for(int i=1;i<thang;i++){ 
	    ntn+=soNgayTrongThang(thang, nam); 
	}
	ntn+=ngay;
	return ntn;
  }
// in ra ngày hôm qua của ngày nhập
void inNgayTruocDo(int ngay, int thang, int nam){
	if(ngay==1){
	  if(thang==1){
		  	ngay=31;
		  	thang=12;
		  	nam--;
	  }else{
		  	thang--;
		  	ngay=soNgayTrongThang(thang, nam);
	  }
  }else{ 
  	   ngay--; 
  }
	printf("\nNgay truoc do: %d/%d/%d", ngay, thang, nam);
}
// in ra ngày mai của ngày nhập	
void ngaySauDo(int ngay, int thang, int nam){
	int nct = soNgayTrongThang(thang, nam);
	if(ngay==nct){
		if(thang==12){
			ngay=1;
			thang=1;
			nam++;
	    }else{
	    	ngay=1;
			thang++;
		}
	}else{ 
		ngay++; 
	}
	printf("\nNgay sau do: %d/%d/%d", ngay, thang, nam);
}

int main(){
	int ngay, thang, nam;
	do{
	printf("Nhap vao ngay/thang/nam: ");
	scanf("%d %d %d",&ngay, &thang, &nam);
}while(ngay<1||ngay>31||thang<1||thang>12||nam<1);
   printf("So ngay cua thang: %d",soNgayTrongThang(thang, nam));
	printf("\nNgay trong nam: %d", ngayTrongNam(ngay, thang, nam));
	inNgayTruocDo(ngay, thang, nam);
	ngaySauDo(ngay, thang, nam);
