#include "stdio.h"
int giaithua(int n){
	if(n==1 || n==0)
	   return 1;
	else 
	   return n*giaithua(n-1);
	}
int main(){
	int n, gt;
	printf("Nhap n: ");
	scanf("%d", &n);
	gt=giaithua(n);
	printf("%d! = %d", n, gt);
	}
	
